# ---------------------------------------------------------------------------
# prismAI environment variables
# Copy this file to `.env` for local development and set the same keys in the
# Vercel dashboard (Project → Settings → Environment Variables) for production.
# ---------------------------------------------------------------------------

# --- Database (Vercel Postgres) --------------------------------------------
# When you create a Vercel Postgres store these are added to the project
# automatically. For local dev, run `vercel env pull .env` to fetch them, or
# paste the values from the Vercel dashboard.
POSTGRES_PRISMA_URL="postgres://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgres://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth (custom jose JWT — NOT NextAuth) ---------------------------------
# Secret used to sign session JWTs. Must be 32+ characters.
# Generate a strong one with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-32-char-minimum-random-string"

# --- Google OAuth / Gmail (optional) ---------------------------------------
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Optional. If unset, the app derives the redirect URI from the request origin
# (e.g. https://<your-app>.vercel.app/api/auth/google/callback). Set this only
# if you want to pin a stable custom-domain callback URL.
GOOGLE_REDIRECT_URI=""

# --- Gmail push notifications (optional, advanced) -------------------------
# Google Cloud Pub/Sub topic for Gmail watch. Leave blank to disable.
GMAIL_PUBSUB_TOPIC=""
# Shared secret used to verify inbound Gmail push webhooks.
GMAIL_PUSH_WEBHOOK_SECRET=""
